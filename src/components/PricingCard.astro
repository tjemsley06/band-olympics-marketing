---
interface Props {
  tier: string;
  price: string;
  students: string;
  popular?: boolean;
}

const { tier, price, students, popular = false } = Astro.props;
---

<div
  class:list={[
    "relative flex flex-col p-7 rounded-xl border transition-all duration-300 hover:translate-y-[-4px]",
    popular
      ? "border-primary/50 bg-primary/[0.06] shadow-[0_0_40px_rgba(124,58,237,0.15)] hover:shadow-[0_0_50px_rgba(124,58,237,0.25)]"
      : "border-primary/15 bg-card/40 hover:border-primary/30 hover:shadow-[0_0_30px_rgba(124,58,237,0.08)]",
  ]}
>
  {popular && (
    <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
      <span class="px-4 py-1.5 text-[10px] font-black uppercase tracking-[0.08em] bg-primary text-primary-foreground rounded-full shadow-[0_0_20px_rgba(124,58,237,0.4)] whitespace-nowrap">
        Most Popular
      </span>
    </div>
  )}
  <h3 class="text-lg font-bold text-foreground mb-1">{tier}</h3>
  <p class="text-muted text-sm mb-5">{students}</p>
  <div class="mb-7">
    <span class="text-4xl font-black text-foreground">{price}</span>
    <span class="text-muted text-sm font-medium">/year</span>
  </div>
  <a
    href="/contact"
    class:list={[
      "inline-flex items-center justify-center px-6 py-3 text-sm font-bold rounded-lg transition-all duration-200 mt-auto",
      popular
        ? "bg-primary text-primary-foreground hover:bg-primary-hover shadow-[0_0_20px_rgba(124,58,237,0.3)] hover:shadow-[0_0_30px_rgba(124,58,237,0.5)]"
        : "border border-primary/30 text-foreground hover:bg-primary/10 hover:border-primary/50",
    ]}
  >
    Get Started
  </a>
</div>
