---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export const prerender = true;

const inputClass = "w-full px-4 py-3.5 rounded-xl bg-card/60 border border-primary/15 text-foreground placeholder-muted/50 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary/40 transition-all duration-200";
---

<BaseLayout title="Contact \u2014 BandXP.Live">
  <Header slot="header" />

  <section
    class="pt-36 pb-24 px-6"
    style="background: radial-gradient(ellipse at top center, #4c1d95 0%, #1a1a2e 30%, #0a0a0a 60%);"
  >
    <div class="max-w-[550px] mx-auto">
      <h1 class="text-4xl font-black text-foreground text-center mb-4 tracking-tight">Get in touch</h1>
      <p class="text-muted text-center mb-12 leading-relaxed">
        Have questions about BandXP.Live? Want to see it in action before signing up? We'd love to hear from you.
      </p>

      <form id="contact-form" class="space-y-5 p-8 rounded-2xl border border-primary/15 bg-background/60" style="backdrop-filter: blur(12px);">
        <div>
          <label for="name" class="block text-sm font-semibold text-foreground mb-2">Name</label>
          <input type="text" id="name" name="name" required class={inputClass} placeholder="Your name" />
        </div>

        <div>
          <label for="school" class="block text-sm font-semibold text-foreground mb-2">School Name</label>
          <input type="text" id="school" name="school" required class={inputClass} placeholder="Your school" />
        </div>

        <div>
          <label for="email" class="block text-sm font-semibold text-foreground mb-2">Email</label>
          <input type="email" id="email" name="email" required class={inputClass} placeholder="you@school.edu" />
        </div>

        <div>
          <label for="students" class="block text-sm font-semibold text-foreground mb-2">Estimated Student Count</label>
          <select id="students" name="students" required class={inputClass}>
            <option value="" disabled selected>Select a range</option>
            <option value="under-100">Under 100</option>
            <option value="100-150">100 - 150</option>
            <option value="150-200">150 - 200</option>
            <option value="200-300">200 - 300</option>
            <option value="300+">300+</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-semibold text-foreground mb-2">Message</label>
          <textarea id="message" name="message" rows="4" required class:list={[inputClass, "resize-y"]} placeholder="Tell us about your program and how we can help..."></textarea>
        </div>

        <div id="form-message" class="hidden rounded-xl p-4 text-sm font-medium"></div>

        <button
          type="submit"
          id="submit-btn"
          class="w-full px-8 py-3.5 text-base font-bold rounded-xl bg-primary text-primary-foreground hover:bg-primary-hover transition-all duration-200 shadow-[0_0_25px_rgba(124,58,237,0.3)] hover:shadow-[0_0_35px_rgba(124,58,237,0.5)] disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Send Message
        </button>
      </form>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;
  const msg = document.getElementById("form-message") as HTMLDivElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = "Sending...";
    msg.classList.add("hidden");

    const data = {
      name: (form.querySelector("#name") as HTMLInputElement).value,
      school: (form.querySelector("#school") as HTMLInputElement).value,
      email: (form.querySelector("#email") as HTMLInputElement).value,
      students: (form.querySelector("#students") as HTMLSelectElement).value,
      message: (form.querySelector("#message") as HTMLTextAreaElement).value,
    };

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        msg.textContent = "Message sent! We'll get back to you soon.";
        msg.className = "rounded-xl p-4 text-sm font-medium bg-success/10 text-success border border-success/30";
        form.reset();
      } else {
        const err = await res.json();
        throw new Error(err.error || "Something went wrong");
      }
    } catch (error) {
      msg.textContent = error instanceof Error ? error.message : "Something went wrong. Please try again.";
      msg.className = "rounded-xl p-4 text-sm font-medium bg-danger/10 text-danger border border-danger/30";
    } finally {
      btn.disabled = false;
      btn.textContent = "Send Message";
    }
  });
</script>
