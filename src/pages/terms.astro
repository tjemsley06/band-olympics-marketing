---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export const prerender = false;
---

<BaseLayout title="Terms of Service \u2014 BandXP">
  <Header slot="header" />

  <section class="pt-36 pb-24 px-6">
    <div class="max-w-[750px] mx-auto">
      <h1 class="text-4xl font-black text-foreground mb-2 tracking-tight">Terms of Service</h1>
      <p class="text-muted text-sm mb-14">Last updated: March 27, 2026</p>

      <div class="space-y-10">
        {[
          { title: "Acceptance of Terms", body: 'By accessing or using BandXP ("the Service"), you agree to be bound by these Terms of Service. If you are registering on behalf of a school or organization, you represent that you have the authority to bind that organization to these terms.' },
          { title: "Description of Service", body: "BandXP is a structured achievement tracking platform for band programs. The Service allows school administrators and staff to create events, score students, manage rosters, and maintain real-time leaderboards. Students access their profiles and achievements via school-assigned PINs." },
          { title: "Account Registration", body: "To use the Service, a school administrator must register using a valid invitation link or approved registration process. You are responsible for maintaining the confidentiality of your account credentials and for all activities that occur under your account." },
          { title: "Subscriptions and Billing", body: "The Service is offered on an annual subscription basis. Pricing is determined by the number of students in your program. All new schools receive a 30-day free trial. After the trial period, a valid subscription is required to continue using the Service. Subscriptions renew automatically unless cancelled before the renewal date." },
          { title: "Cancellation", body: "You may cancel your subscription at any time. Upon cancellation, you will retain access to the Service until the end of your current billing period. No refunds are provided for partial billing periods. After your subscription expires, your account will be deactivated and access will be restricted." },
          { title: "Acceptable Use", body: "You agree to use the Service only for its intended purpose of managing band program achievements and scoring. You agree not to: (a) use the Service for any unlawful purpose; (b) attempt to gain unauthorized access to the Service or other accounts; (c) interfere with or disrupt the Service; or (d) upload content that is harmful, offensive, or violates the rights of others." },
          { title: "Data Ownership", body: "All student data, scores, events, and school-specific content entered into the Service remains the property of the school. We do not claim ownership of your data. You grant us a limited license to use your data solely for the purpose of providing and improving the Service." },
          { title: "Service Availability", body: "We strive to maintain high availability of the Service but do not guarantee uninterrupted access. We may perform maintenance, updates, or modifications that temporarily affect availability. We will make reasonable efforts to notify users of planned downtime in advance." },
          { title: "Limitation of Liability", body: "To the maximum extent permitted by law, BandXP shall not be liable for any indirect, incidental, special, consequential, or punitive damages arising out of or related to your use of the Service. Our total liability for any claims arising from the Service shall not exceed the amount you paid for the Service in the twelve months preceding the claim." },
          { title: "Changes to Terms", body: "We may update these Terms of Service from time to time. We will notify registered users of material changes via email. Continued use of the Service after changes constitutes acceptance of the updated terms." },
        ].map((section) => (
          <div>
            <h2 class="text-xl font-bold text-foreground mb-3">{section.title}</h2>
            <p class="text-muted leading-relaxed">{section.body}</p>
          </div>
        ))}

        <div>
          <h2 class="text-xl font-bold text-foreground mb-3">Contact</h2>
          <p class="text-muted leading-relaxed">
            For questions about these Terms of Service, contact us at <a href="mailto:support@bandxp.com" class="text-primary hover:text-primary-hover font-semibold transition-colors">support@bandxp.com</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
